DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-only-secret-change-me"

# Decentro (ticket #14) — optional. Leave unset to run against the fakes
# (FakePaymentProvider / FakeIdentityProvider). Set all four to switch the
# real adapters on; see server/src/lib/env.ts's hasDecentroCredentials.
# DECENTRO_CLIENT_ID=
# DECENTRO_CLIENT_SECRET=
# DECENTRO_ENV=staging
# DECENTRO_VIRTUAL_VPA=
# DECENTRO_CONSUMER_URN=
# Shared secret for the deposit-confirmation webhook (ticket #15) — optional,
# the check is skipped when unset. See deposits/webhook-router.ts.
# DECENTRO_WEBHOOK_SECRET=
