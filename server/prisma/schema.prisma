generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  phoneNumber    String       @unique
  createdAt      DateTime     @default(now())
  // Full KYC (ticket #12, ADR 0007) — required to become an Organizer, never
  // required just to join/deposit as a Member. Stubbed here: set instantly by
  // POST /auth/verify rather than a real verification flow, until the real
  // BaaS/UPI partner integration (ticket #14) wires up an actual KYC check.
  isVerified     Boolean      @default(false)
  // Freemium subscription (ticket #13, ADR 0011) — waives the per-Spend fee,
  // lifts the concurrent-Active-Pool cap, and unlocks cross-Pool analytics.
  // Stubbed: set instantly by POST /auth/subscribe, no real billing yet.
  isSubscribed   Boolean      @default(false)
  organizedPools Pool[]
  memberships    Membership[]
  deposits       Deposit[]
  pendingDeposits PendingDeposit[]
  spends         Spend[]
  reimbursements Reimbursement[]
  refunds        Refund[]
  refundVotes    RefundVote[]
}

model Pool {
  id     String @id @default(cuid())
  name   String
  // "EQUAL_SPLIT" | "OPEN" — string, not a Prisma enum, since the sqlite connector doesn't support enums.
  type   String
  // Required (and positive) for EQUAL_SPLIT, always null for OPEN. In paise (1 INR = 100 paise) to avoid float money bugs.
  perPersonAmountPaise Int?
  // "ACTIVE" | "LOCKED" | "CLOSED"
  state       String   @default("ACTIVE")
  organizerId String
  organizer   User     @relation(fields: [organizerId], references: [id])
  createdAt   DateTime @default(now())
  // Six-digit code for manual Pool joining. An Invite Link is just this Pool's
  // id embedded in a deep link — no separate stored field needed for that.
  joinCode    String       @unique
  memberships    Membership[]
  deposits       Deposit[]
  pendingDeposits PendingDeposit[]
  spends         Spend[]
  reimbursements Reimbursement[]
  refunds        Refund[]
  refundVotes    RefundVote[]

  @@index([organizerId])
}

model Deposit {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  // In paise. Never validated against the Pool's per-person amount — Equal
  // Split deposits arriving at a different amount are recorded, not rejected.
  amountPaise Int
  createdAt   DateTime @default(now())

  @@index([poolId])
  @@index([poolId, userId])
}

// Bookkeeping for confirming a deposit intent server-side, closing the gap
// where a real Payment Provider (ticket #14, #15) confirms payment via an
// async webhook rather than synchronously: created when the intent's QR is
// generated (so we know which Member it was for before any money moves),
// consumed exactly once — by whichever of self-report or webhook arrives
// first — so the two paths can't double-credit the same payment.
model PendingDeposit {
  id          String    @id @default(cuid())
  providerRef String    @unique
  poolId      String
  pool        Pool      @relation(fields: [poolId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  // The Deposit row created on first confirmation — kept so a repeat
  // confirmation (idempotent replay) can return the same result instead of
  // re-validating or re-crediting.
  resultingDepositId String?
  consumedAt         DateTime?
  createdAt          DateTime  @default(now())

  @@index([poolId])
}

model Spend {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  // The merchant's UPI reference the Organizer scanned/entered.
  merchantRef String
  // In paise. The per-Spend fee (ADR 0010) — Pool Pay's own monetization,
  // never applied to Deposits or Refunds.
  amountPaise Int
  feePaise    Int
  createdAt   DateTime @default(now())

  @@index([poolId])
}

model Reimbursement {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  // The Member being paid back. Named memberId (not userId) since, unlike
  // Deposit/Spend, this row isn't about the actor (always the Organizer) —
  // it's about who received the money.
  memberId String
  member   User   @relation(fields: [memberId], references: [id])
  vpa      String
  // In paise. No fee — Reimbursements are never fee-bearing (ADR 0010).
  amountPaise Int
  createdAt   DateTime @default(now())

  @@index([poolId])
}

model Refund {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  // The Member being refunded, paid pro-rata against their total contributions
  // (see closePool) — not the Organizer, who initiates Closure but isn't
  // treated specially in the payout itself.
  memberId String
  member   User   @relation(fields: [memberId], references: [id])
  vpa      String
  // In paise. No fee — Refunds are never fee-bearing (ADR 0010).
  amountPaise Int
  createdAt   DateTime @default(now())

  @@index([poolId])
}

model RefundVote {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  // One vote per Member per Pool (ADR 0009) — casting again is a no-op, not
  // an additional vote.
  @@unique([poolId, userId])
  @@index([poolId])
}

model Membership {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  // "ORGANIZER" | "MEMBER"
  role      String
  joinedAt  DateTime @default(now())
  // Set when the Organizer removes this Member (ticket #11). A removed
  // Membership row is kept (not deleted) purely as an audit trail — access
  // checks (find/listByPool) treat it as absent. Deposits reference userId
  // directly, so prior contributions still count at Closure regardless
  // (ADR 0006).
  removedAt DateTime?

  @@unique([poolId, userId])
}

model OtpRequest {
  id          String    @id @default(cuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([phoneNumber])
}
