generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  phoneNumber    String       @unique
  createdAt      DateTime     @default(now())
  organizedPools Pool[]
  memberships    Membership[]
  deposits       Deposit[]
  spends         Spend[]
  reimbursements Reimbursement[]
  refunds        Refund[]
}

model Pool {
  id     String @id @default(cuid())
  name   String
  // "EQUAL_SPLIT" | "OPEN" — string, not a Prisma enum, since the sqlite connector doesn't support enums.
  type   String
  // Required (and positive) for EQUAL_SPLIT, always null for OPEN. In paise (1 INR = 100 paise) to avoid float money bugs.
  perPersonAmountPaise Int?
  // "ACTIVE" | "LOCKED" | "CLOSED"
  state       String   @default("ACTIVE")
  organizerId String
  organizer   User     @relation(fields: [organizerId], references: [id])
  createdAt   DateTime @default(now())
  // Six-digit code for manual Pool joining. An Invite Link is just this Pool's
  // id embedded in a deep link — no separate stored field needed for that.
  joinCode    String       @unique
  memberships    Membership[]
  deposits       Deposit[]
  spends         Spend[]
  reimbursements Reimbursement[]
  refunds        Refund[]

  @@index([organizerId])
}

model Deposit {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  // In paise. Never validated against the Pool's per-person amount — Equal
  // Split deposits arriving at a different amount are recorded, not rejected.
  amountPaise Int
  createdAt   DateTime @default(now())

  @@index([poolId])
  @@index([poolId, userId])
}

model Spend {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  // The merchant's UPI reference the Organizer scanned/entered.
  merchantRef String
  // In paise. The per-Spend fee (ADR 0010) — Pool Pay's own monetization,
  // never applied to Deposits or Refunds.
  amountPaise Int
  feePaise    Int
  createdAt   DateTime @default(now())

  @@index([poolId])
}

model Reimbursement {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  // The Member being paid back. Named memberId (not userId) since, unlike
  // Deposit/Spend, this row isn't about the actor (always the Organizer) —
  // it's about who received the money.
  memberId String
  member   User   @relation(fields: [memberId], references: [id])
  vpa      String
  // In paise. No fee — Reimbursements are never fee-bearing (ADR 0010).
  amountPaise Int
  createdAt   DateTime @default(now())

  @@index([poolId])
}

model Refund {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  // The Member being refunded, paid pro-rata against their total contributions
  // (see closePool) — not the Organizer, who initiates Closure but isn't
  // treated specially in the payout itself.
  memberId String
  member   User   @relation(fields: [memberId], references: [id])
  vpa      String
  // In paise. No fee — Refunds are never fee-bearing (ADR 0010).
  amountPaise Int
  createdAt   DateTime @default(now())

  @@index([poolId])
}

model Membership {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  // "ORGANIZER" | "MEMBER"
  role      String
  joinedAt  DateTime @default(now())

  @@unique([poolId, userId])
}

model OtpRequest {
  id          String    @id @default(cuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([phoneNumber])
}
