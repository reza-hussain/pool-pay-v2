generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String       @id @default(cuid())
  phoneNumber    String       @unique
  createdAt      DateTime     @default(now())
  organizedPools Pool[]
  memberships    Membership[]
  deposits       Deposit[]
}

model Pool {
  id     String @id @default(cuid())
  name   String
  // "EQUAL_SPLIT" | "OPEN" — string, not a Prisma enum, since the sqlite connector doesn't support enums.
  type   String
  // Required (and positive) for EQUAL_SPLIT, always null for OPEN. In paise (1 INR = 100 paise) to avoid float money bugs.
  perPersonAmountPaise Int?
  // "ACTIVE" | "LOCKED" | "CLOSED"
  state       String   @default("ACTIVE")
  organizerId String
  organizer   User     @relation(fields: [organizerId], references: [id])
  createdAt   DateTime @default(now())
  // Six-digit code for manual Pool joining. An Invite Link is just this Pool's
  // id embedded in a deep link — no separate stored field needed for that.
  joinCode    String       @unique
  memberships Membership[]
  deposits    Deposit[]

  @@index([organizerId])
}

model Deposit {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  // In paise. Never validated against the Pool's per-person amount — Equal
  // Split deposits arriving at a different amount are recorded, not rejected.
  amountPaise Int
  createdAt   DateTime @default(now())

  @@index([poolId])
  @@index([poolId, userId])
}

model Membership {
  id     String @id @default(cuid())
  poolId String
  pool   Pool   @relation(fields: [poolId], references: [id])
  userId String
  user   User   @relation(fields: [userId], references: [id])
  // "ORGANIZER" | "MEMBER"
  role      String
  joinedAt  DateTime @default(now())

  @@unique([poolId, userId])
}

model OtpRequest {
  id          String    @id @default(cuid())
  phoneNumber String
  code        String
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([phoneNumber])
}
